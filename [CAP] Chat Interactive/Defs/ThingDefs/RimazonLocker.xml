<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>RimazonLockerSmall</defName>
    <label>small rimazon locker</label>
    <description>A compact locker designed for secure Rimazon deliveries from chat viewers. Items appear inside without visual stacking on top. Low-priority storage by default, with a limit on total stacks to prevent overflow.</description>
    <thingClass>CAP_ChatInteractive.Building_RimazonLocker</thingClass>
    <category>Building</category>
    <graphicData>
      <texPath>Things/Building/Furniture/RICS_RimazonLockerSmall</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,2)</drawSize>
      <drawOffset>(0, 0, 0.5)</drawOffset>
    </graphicData>
    <size>(1,1)</size>
    <rotatable>False</rotatable>
    <passability>Impassable</passability>
    <fillPercent>1</fillPercent>
    <statBases>
      <MaxHitPoints>200</MaxHitPoints>
      <WorkToBuild>1000</WorkToBuild>
      <Flammability>0</Flammability>
      <Beauty>0</Beauty>
      <Mass>10</Mass>
    </statBases>
    <costList>
      <Steel>50</Steel>
      <ComponentIndustrial>1</ComponentIndustrial>
    </costList>
    <comps>
      <li Class="CompProperties_Forbiddable" />
    </comps>
    <modExtensions>
      <li Class="CAP_ChatInteractive.LockerExtension">
        <maxStacks>24</maxStacks>
      </li>
    </modExtensions>
    <constructEffect>ConstructMetal</constructEffect>
    <altitudeLayer>Building</altitudeLayer>
    <thingCategories>
      <li>BuildingsMisc</li>
    </thingCategories>
    <minifiedDef>MinifiedThing</minifiedDef>
    <designationCategory>Misc</designationCategory>
    <uiOrder>2500</uiOrder>
    <selectable>true</selectable>


    <!-- CRITICAL: Proper storage settings based on shelf example -->
    <building>
      <!--<storageGroupTag>Shelf</storageGroupTag>-->
      <!--<maxItemsInCell>0</maxItemsInCell>-->
      <!-- Fixed storage settings (cannot be changed by player) -->
      <fixedStorageSettings>
        <filter>
          <disallowNotEverStorable>true</disallowNotEverStorable>
          <categories>
            <li>Root</li>
            <!-- This is the "Everything" category -->
          </categories>
          <disallowedCategories>
            <li>Chunks</li>
            <li>Plants</li>
            <!-- <li>Buildings</li> We want to allow buildings -->
          </disallowedCategories>
          <specialFiltersToDisallow>
            <li>AllowLargeCorpses</li>
            <li>AllowCorpsesColonist</li>
            <li>AllowCorpsesStranger</li>
            <li>AllowDeadmansApparel</li>
          </specialFiltersToDisallow>
        </filter>
      </fixedStorageSettings>

      <!-- Default storage settings (player can change these) -->
      <!-- Unstored = pawns will haul items OUT to any better stockpile (vanilla pattern for delivery boxes) -->
      <defaultStorageSettings>
        <priority>Unstored</priority>
        <filter>
          <!-- Allow common categories by default -->
          <categories>
            <li>Foods</li>
            <li>Manufactured</li>
            <li>ResourcesRaw</li>
            <li>Items</li>
            <li>Weapons</li>
            <li>Apparel</li>
            <li>Drugs</li>
            <li>Medicine</li>
            <li>Building</li>
          </categories>
        </filter>
      </defaultStorageSettings>
    </building>
    <!--<inspectorTabs Inherit="True">-->
    <!--<inspectorTabs>
      <li>ITab_ContainerStorage</li>
      <li>ITab_LockerContents</li>
    </inspectorTabs>-->
  </ThingDef>
</Defs>